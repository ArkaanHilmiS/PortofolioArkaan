</div><!-- /main-content -->

<script>
// ============================
// LANDING
// ============================
let selRole = '';
function pickRole(r, el) {
  selRole = r;
  document.querySelectorAll('.role-card').forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
}
function enter() {
  const name = document.getElementById('vname').value.trim();
  const role = selRole || 'Pengunjung';
  let w = '';
  if (name) w = `Halo, ${name}! Selamat datang 👋`;
  else if (role === 'HRD Perusahaan') w = 'Halo, Bapak/Ibu HRD! Selamat datang 👋';
  else if (role === 'Mahasiswa') w = 'Halo, sesama Mahasiswa! Selamat datang 👋';
  else if (role === 'Kolega / Rekan') w = 'Halo, Rekan! Selamat datang 👋';
  else if (role === 'Calon Klien') w = 'Halo! Terima kasih sudah mampir 👋';
  else w = 'Selamat datang di portfolio Arkaan! 👋';
  document.getElementById('hwelcome').textContent = w;
  document.getElementById('landing').classList.add('hidden');
  setTimeout(() => {
    document.getElementById('navbar').style.display = 'flex';
    document.getElementById('main-content').classList.add('vis');
    document.getElementById('landing').style.display = 'none';
    setTimeout(animateBars, 600);
    initReveal();
  }, 800);
}
document.getElementById('vname').addEventListener('keydown', e => { if (e.key === 'Enter') enter(); });

// ============================
// NAVBAR
// ============================
function toggleNav() { document.getElementById('nlinks').classList.toggle('open'); }
window.addEventListener('scroll', () => {
  const sy = window.scrollY + 90;
  ['home','education','experience','projects','training','gallery','freelance'].forEach(id => {
    const el = document.getElementById(id); if (!el) return;
    const a = document.querySelector(`.n-links a[href="#${id}"]`);
    if (a) a.classList.toggle('active', sy >= el.offsetTop && sy < el.offsetTop + el.offsetHeight);
  });
});

// ============================
// SKILL BARS
// ============================
function animateBars() {
  document.querySelectorAll('.s-fill').forEach(b => { b.style.width = b.getAttribute('data-w') + '%'; });
}

// ============================
// SCROLL REVEAL
// ============================
function initReveal() {
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); });
  }, { threshold: 0.1, rootMargin: '0px 0px -35px 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
}

// ============================
// MESSAGE FORM
// ============================
function sendMsg() {
  const n = document.getElementById('mn').value.trim();
  const m = document.getElementById('mm').value.trim();
  if (!n || !m) { alert('Mohon isi nama dan pesan terlebih dahulu.'); return; }
  const ok = document.getElementById('ok-msg');
  ok.style.display = 'block';
  document.getElementById('mn').value = '';
  document.getElementById('mc').value = '';
  document.getElementById('mm').value = '';
  document.getElementById('mp').value = '';
  setTimeout(() => { ok.style.display = 'none'; }, 5000);
}

// ============================
// DOWNLOAD PPT
// ============================
async function dlPPT() {
  const btn = document.querySelector('.btn-ppt');
  const prog = document.getElementById('ppt-prog');
  const fill = document.getElementById('pfill');
  const st = document.getElementById('ppt-status');
  btn.disabled = true; btn.innerHTML = '⏳ Memproses…';
  prog.style.display = 'block';
  const steps = [[10,'Mengumpulkan data profil…'],[25,'Membuat slide Pendidikan…'],[45,'Membuat slide Pengalaman…'],[62,'Membuat slide Proyek…'],[78,'Membuat slide Keahlian…'],[92,'Menyusun slide Freelance & Penutup…'],[100,'Selesai! Mengunduh…']];
  for (const [p, s] of steps) { fill.style.width = p + '%'; st.textContent = s; await new Promise(r => setTimeout(r, 380)); }
  await makePPT();
  btn.disabled = false; btn.innerHTML = '✅ Berhasil Diunduh!';
  setTimeout(() => { btn.innerHTML = '⬇️ Download Portfolio.pptx'; prog.style.display = 'none'; fill.style.width = '0'; }, 3000);
}

async function makePPT() {
  if (!window.PptxGenJS) {
    await new Promise((res, rej) => {
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/pptxgenjs@3/dist/pptxgen.bundle.js';
      s.onload = res; s.onerror = rej; document.head.appendChild(s);
    });
  }
  const pptx = new PptxGenJS();
  pptx.title = 'Portfolio – Arkaan Hilmi Suharsoyo';
  pptx.author = 'Arkaan Hilmi Suharsoyo';
  const N = '0D1B3E', A = '2563EB', G = 'C9A84C', W = 'FFFFFF', LG = 'F1F5F9', DG = '64748B';

  function darkBg(sl) {
    sl.addShape(pptx.ShapeType.rect, {x:0,y:0,w:'100%',h:'100%',fill:{color:N}});
    sl.addShape(pptx.ShapeType.rect, {x:0,y:0,w:'100%',h:0.08,fill:{color:G}});
    sl.addShape(pptx.ShapeType.rect, {x:0,y:7.42,w:'100%',h:0.08,fill:{color:G}});
  }
  function lightBg(sl) {
    sl.addShape(pptx.ShapeType.rect, {x:0,y:0,w:'100%',h:'100%',fill:{color:LG}});
    sl.addShape(pptx.ShapeType.rect, {x:0,y:0,w:'100%',h:0.08,fill:{color:N}});
  }
  function pg(sl, n) { sl.addText(`${n}`, {x:9.1,y:7.1,w:.5,h:.3,fontSize:9,color:'AAAAAA',align:'right'}); }

  // SLIDE 1 – COVER
  const s1 = pptx.addSlide(); darkBg(s1);
  s1.addShape(pptx.ShapeType.rect, {x:.6,y:1.8,w:8.8,h:4,fill:{color:'1A2F5E'},line:{color:'2A4A8A',width:1}});
  s1.addShape(pptx.ShapeType.ellipse, {x:3.7,y:0.85,w:1.1,h:1.1,fill:{color:A},line:{color:G,width:3}});
  s1.addText('AH', {x:3.7,y:0.85,w:1.1,h:1.1,fontSize:24,bold:true,color:W,align:'center',valign:'middle'});
  s1.addText('ARKAAN HILMI SUHARSOYO', {x:1,y:2.05,w:8,h:.5,fontSize:25,bold:true,color:W,align:'center',fontFace:'Georgia'});
  s1.addShape(pptx.ShapeType.rect, {x:3.5,y:2.68,w:3,h:.05,fill:{color:G}});
  s1.addText('Mahasiswa Sistem Informasi', {x:1,y:2.85,w:8,h:.35,fontSize:13,color:'A0B4D0',align:'center'});
  s1.addText('Institut Teknologi Sepuluh Nopember · Surabaya', {x:1,y:3.22,w:8,h:.3,fontSize:11,color:'7A90A8',align:'center'});
  s1.addText('🌐 Web Dev  •  📊 Data Analytics  •  🤖 Machine Learning  •  📸 Fotografi', {x:1,y:3.82,w:8,h:.32,fontSize:10,color:'A0B4D0',align:'center'});
  s1.addText('P O R T F O L I O', {x:1,y:6.95,w:8,h:.28,fontSize:8,color:G,align:'center',bold:true,charSpacing:6});

  // SLIDE 2 – PROFIL
  const s2 = pptx.addSlide(); lightBg(s2); pg(s2,2);
  s2.addShape(pptx.ShapeType.rect, {x:0,y:0,w:3.2,h:7.5,fill:{color:N}});
  s2.addShape(pptx.ShapeType.ellipse, {x:.85,y:.8,w:1.5,h:1.5,fill:{color:A},line:{color:G,width:2}});
  s2.addText('AH', {x:.85,y:.8,w:1.5,h:1.5,fontSize:28,bold:true,color:W,align:'center',valign:'middle'});
  s2.addText('Arkaan Hilmi\nSuharsoyo', {x:.15,y:2.55,w:2.9,h:.72,fontSize:14,bold:true,color:W,align:'center',fontFace:'Georgia'});
  s2.addText('Sistem Informasi · ITS', {x:.15,y:3.32,w:2.9,h:.32,fontSize:9,color:'A0B4D0',align:'center'});
  [['📧','arkaan@email.com'],['💼','LinkedIn'],['🐙','GitHub'],['📱','WhatsApp']].forEach(([ic,lb],i)=>{
    s2.addText(`${ic} ${lb}`, {x:.15,y:4.2+i*.4,w:2.9,h:.32,fontSize:9,color:'A0B4D0',align:'center'});
  });
  s2.addText('PROFIL', {x:3.5,y:.3,w:5.8,h:.35,fontSize:11,bold:true,color:N,charSpacing:4});
  s2.addShape(pptx.ShapeType.rect, {x:3.5,y:.7,w:1,h:.05,fill:{color:G}});
  s2.addText('Mahasiswa tekno-kreatif dari ITS Surabaya yang passionate di bidang web development, analisis data, machine learning, dan visualisasi. Berorientasi pada solusi nyata yang berdampak.', {x:3.5,y:.9,w:5.8,h:.95,fontSize:10,color:DG,wrap:true});
  [['IPK','3.7+'],['Proyek','10+'],['Org','5+']].forEach(([lb,vl],i)=>{
    const xp=3.5+i*2;
    s2.addShape(pptx.ShapeType.rect, {x:xp,y:2.1,w:1.8,h:.88,fill:{color:'E8ECF4'},line:{color:'D0D8EC',width:.5}});
    s2.addText(vl, {x:xp,y:2.18,w:1.8,h:.42,fontSize:18,bold:true,color:N,align:'center',fontFace:'Georgia'});
    s2.addText(lb, {x:xp,y:2.62,w:1.8,h:.25,fontSize:8,color:DG,align:'center'});
  });
  s2.addText('MINAT KE DEPAN', {x:3.5,y:3.2,w:5.8,h:.28,fontSize:9,bold:true,color:N,charSpacing:2});
  ['🤖 AI / ML Engineer','🌐 Full-Stack Dev','📊 Data Scientist','☁️ Cloud & DevOps','📸 Creative Director','🎓 Educator / Mentor'].forEach((it,i)=>{
    const col=i%3, row=Math.floor(i/3);
    s2.addShape(pptx.ShapeType.rect, {x:3.5+col*1.95,y:3.6+row*.55,w:1.82,h:.42,fill:{color:W},line:{color:'D0D8EC',width:.5}});
    s2.addText(it, {x:3.5+col*1.95,y:3.6+row*.55,w:1.82,h:.42,fontSize:8,color:N,align:'center',valign:'middle',wrap:true});
  });

  // SLIDE 3 – PENDIDIKAN
  const s3 = pptx.addSlide(); lightBg(s3); pg(s3,3);
  s3.addText('PENDIDIKAN', {x:.5,y:.2,w:9,h:.38,fontSize:11,bold:true,color:N,charSpacing:4});
  s3.addShape(pptx.ShapeType.rect, {x:.5,y:.62,w:1,h:.05,fill:{color:G}});
  [{logo:'ITS',period:'2022 — Sekarang',school:'Institut Teknologi Sepuluh Nopember',major:'Sistem Informasi · FTEIC',ipk:'IPK 3.7+',y:.9},{logo:'SMA',period:'2019 — 2022',school:'SMA [Nama Sekolah]',major:'IPA · [Kota Asal]',ipk:'Nilai Memuaskan',y:4.0}].forEach(ed=>{
    s3.addShape(pptx.ShapeType.rect, {x:.4,y:ed.y,w:9.2,h:2.8,fill:{color:W},line:{color:'D0D8EC',width:.5}});
    s3.addShape(pptx.ShapeType.rect, {x:.4,y:ed.y,w:.08,h:2.8,fill:{color:A}});
    s3.addShape(pptx.ShapeType.rect, {x:.6,y:ed.y+.28,w:1,h:1,fill:{color:N}});
    s3.addText(ed.logo, {x:.6,y:ed.y+.28,w:1,h:1,fontSize:ed.logo==='ITS'?14:10,bold:true,color:W,align:'center',valign:'middle'});
