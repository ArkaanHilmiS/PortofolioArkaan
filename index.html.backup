          <div class="s-item"><div class="s-label"><span class="s-name">Web Development</span><span class="s-pct">85%</span></div><div class="s-bar"><div class="s-fill" data-w="85"></div></div></div>
          <div class="s-item"><div class="s-label"><span class="s-name">Data Analytics</span><span class="s-pct">80%</span></div><div class="s-bar"><div class="s-fill" data-w="80"></div></div></div>
          <div class="s-item"><div class="s-label"><span class="s-name">Machine Learning</span><span class="s-pct">72%</span></div><div class="s-bar"><div class="s-fill" data-w="72"></div></div></div>
          <div class="s-item"><div class="s-label"><span class="s-name">Power BI / Visualisasi</span><span class="s-pct">78%</span></div><div class="s-bar"><div class="s-fill" data-w="78"></div></div></div>
