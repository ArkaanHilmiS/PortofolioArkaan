    <li><a href="#freelance">Freelance</a></li>
    <li><a href="#msg" class="n-cta">Kirim Pesan</a></li>
  </ul>
  <div class="n-ham" onclick="toggleNav()"><span></span><span></span><span></span></div>
</nav>

<!-- MAIN -->
<div id="main-content">

  <!-- HOME / HERO -->
  <section id="home">
    <div class="h-blob1"></div><div class="h-blob2"></div>
    <div class="h-cont">
      <div class="h-text">
        <div class="h-badge">👋 <span id="hwelcome">Selamat Datang!</span></div>
